# LLM Provider 配置

# 选择 provider: "ark"（豆包，默认）或 "openai"（OpenAI 兼容，兜底）
LLM_PROVIDER=ark

# API Key（必填）
LLM_API_KEY=your-api-key-here

# 以下为可选配置 — 留空则使用 provider 的内置默认值
# Ark 默认:   https://ark.cn-beijing.volces.com/api/v3  /  doubao-seed-2-0-lite-260215
# OpenAI 默认: https://api.openai.com/v1                 /  gpt-4o-mini
LLM_BASE_URL=
LLM_MODEL=

# ⚠️ 旧环境变量 OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL 仍可作为兼容回退使用
